# ============================================================================
# 📝 GatewayEMS - Variables de Entorno
# ============================================================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo como .env:
#    cp .env.example .env
# 
# 2. Edita los valores según tu entorno
# 
# 3. NUNCA commitees el archivo .env a Git (está en .gitignore)
#
# ============================================================================

# ============================================================================
# 🗄️ INFLUXDB - Configuración de la Base de Datos (OPCIONAL)
# ============================================================================
# 
# NOTA: Estas variables son OPCIONALES. Si no se configuran, el sistema
#       funcionará sin persistencia de datos en InfluxDB.
#       Útil para entornos de desarrollo y testing.
# ============================================================================

# URL de conexión a InfluxDB
# Para Docker Compose: http://influxdb:8086
# Para InfluxDB local: http://localhost:8086
# Para InfluxDB remoto: http://tu-servidor.com:8086
INFLUXDB_URL=http://localhost:8086

# Token de autenticación de InfluxDB (mínimo 16 caracteres, recomendado 64)
# Genera uno seguro con cualquiera de estos comandos:
#   openssl rand -base64 64 | tr -d "=+/" | cut -c1-64
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# IMPORTANTE: Este token debe tener permisos de lectura/escritura en el bucket
INFLUXDB_TOKEN=tu_token_super_secreto_de_minimo_64_caracteres_aqui_cambiar

# Usuario administrador de InfluxDB
# Se crea automáticamente en el primer inicio de InfluxDB
INFLUXDB_ADMIN_USER=admin

# Contraseña del administrador (mínimo 8 caracteres, recomendado 16+)
# Usa una contraseña fuerte con letras, números y símbolos
INFLUXDB_ADMIN_PASSWORD=tu_password_seguro_aqui_cambiar

# Organización de InfluxDB (namespace para buckets)
# Puedes usar el nombre de tu empresa o proyecto
INFLUXDB_ORG=gateway_ems

# Bucket principal para almacenar datos Modbus
# Un bucket es como una "base de datos" en InfluxDB
INFLUXDB_BUCKET=modbus_data

# Retención de datos en días (después se eliminan automáticamente)
# Valores comunes:
#   7   = 1 semana
#   30  = 1 mes
#   90  = 3 meses (recomendado)
#   365 = 1 año
#   0   = infinito (sin límite)
INFLUXDB_RETENTION=90

# ============================================================================
# 🔧 OPCIONALES - Configuración Avanzada
# ============================================================================

# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Puerto del servidor (si implementas API REST en el futuro)
# SERVER_PORT=8000

# Zona horaria (útil para timestamps)
# TIMEZONE=America/Mexico_City

# ============================================================================
# 📊 MONITOREO - Para integración futura con Grafana/Prometheus
# ============================================================================

# URL de Grafana (si usas visualización)
# GRAFANA_URL=http://localhost:3000

# API Key de Grafana
# GRAFANA_API_KEY=tu_grafana_api_key_aqui

# ============================================================================
# 🔐 SEGURIDAD - Notas Importantes
# ============================================================================
#
# ⚠️  NUNCA compartas este archivo .env públicamente
# ⚠️  NO lo commitees a Git (verifica .gitignore)
# ⚠️  Usa contraseñas diferentes en producción
# ⚠️  Rota tokens cada 90 días en producción
# ⚠️  Limita permisos del token solo a lo necesario
#
# ============================================================================

# ============================================================================
# 🧪 TESTING - Variables para tests (opcional)
# ============================================================================

# Base de datos de prueba (para tests)
# INFLUXDB_BUCKET_TEST=modbus_data_test

