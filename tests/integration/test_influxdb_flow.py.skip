    def test_flow_with_reconnection(self, influxdb_config, sample_device_results):
        """Test flow with connection loss and recovery."""
        mock_client = MagicMock()
        
        # First health check passes
        mock_health_pass = MagicMock()
        mock_health_pass.status = "pass"
        
        # Simulate health checks: fail, fail, pass (reconnection)
        mock_client.health.side_effect = [
            mock_health_pass,  # Initial connect
            mock_health_pass,  # First write
        ]
        
        mock_write_api = MagicMock()
        mock_client.write_api.return_value = mock_write_api
        
        with patch('src.Database.connection.InfluxDBClient', return_value=mock_client):
            service = ModbusService(influxdb_config)
            
            # Initialize
            assert service.initialize() is True
            
            # First batch - success
            assert service.save_batch(sample_device_results) is True
            
            service.shutdown()
    
    def test_flow_data_type_conversion(self, influxdb_config):
        """Test that data types are correctly converted through the flow."""
        device_result = DeviceReadResult(
            device_name="Test_Device",
            device_id=99,  # int
            identify_device="test-uuid",
            timestamp="2026-03-29T23:06:29.664999Z",
            device_type="CT_Meter",
            data={
                "VOLTAGE": 120,      # int -> should become float
                "CURRENT": 5.5,      # float -> stays float
                "POWER": None,       # None -> should be filtered
                "STATUS": "",        # empty string -> should be filtered
            },
            success=True,
            error=None
        )
        
        # Convert to EnergyPoint
        energy_point = EnergyPoint.from_device_read_result(device_result)
        
        # Verify conversions
        assert "voltage" in energy_point.fields
        assert isinstance(energy_point.fields["voltage"], float)
        assert energy_point.fields["voltage"] == 120.0
        
        assert "current" in energy_point.fields
        assert isinstance(energy_point.fields["current"], float)
        assert energy_point.fields["current"] == 5.5
        
        # None and empty string should be filtered out
        assert "power" not in energy_point.fields
        assert "status" not in energy_point.fields
    
    def test_flow_with_context_manager(self, influxdb_config, sample_device_results):
        """Test using service as context manager."""
        mock_client = MagicMock()
        mock_health = MagicMock()
        mock_health.status = "pass"
        mock_client.health.return_value = mock_health
        mock_write_api = MagicMock()
        mock_client.write_api.return_value = mock_write_api
        
        with patch('src.Database.connection.InfluxDBClient', return_value=mock_client):
            with ModbusService(influxdb_config) as service:
                result = service.save_batch(sample_device_results)
                assert result is True
        
        # Connection should be closed after context
        assert mock_client.close.called
    
    def test_flow_concurrent_batches(self, influxdb_config):
        """Test handling multiple batches in sequence."""
        batch1 = [
            DeviceReadResult(
                device_name="Device_1",
                device_id=1,
                identify_device="uuid-1",
                timestamp="2026-03-29T23:06:29.000000Z",
                device_type="CT_Meter",
                data={"VOLTAGE_A": 120.0},
                success=True,
                error=None
            )
        ]
        
        batch2 = [
            DeviceReadResult(
                device_name="Device_2",
                device_id=2,
                identify_device="uuid-2",
                timestamp="2026-03-29T23:06:30.000000Z",
                device_type="CT_Meter",
                data={"VOLTAGE_A": 121.0},
                success=True,
                error=None
            )
        ]
        
        mock_client = MagicMock()
        mock_health = MagicMock()
        mock_health.status = "pass"
        mock_client.health.return_value = mock_health
        mock_write_api = MagicMock()
        mock_client.write_api.return_value = mock_write_api
        
        with patch('src.Database.connection.InfluxDBClient', return_value=mock_client):
            service = ModbusService(influxdb_config)
            service.initialize()
            
            # Save first batch
            result1 = service.save_batch(batch1)
            assert result1 is True
            
            # Save second batch
            result2 = service.save_batch(batch2)
            assert result2 is True
            
            # Write should be called twice
            assert mock_write_api.write.call_count == 2
            
            service.shutdown()
